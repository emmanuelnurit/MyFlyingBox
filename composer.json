{
    "name": "thelia/myflyingbox-module",
    "description": "MyFlyingBox shipping module for Thelia 2.6 - Multi-carrier shipping with LCE API",
    "license": "LGPL-3.0-or-later",
    "type": "thelia-module",
    "keywords": ["thelia", "shipping", "delivery", "myflyingbox", "lce", "multi-carrier"],
    "authors": [
        {
            "name": "Emmanuel Nurit",
            "email": "enurit@openstudio.fr"
        }
    ],
    "require": {
        "php": ">=8.0",
        "thelia/installer": "~1.1",
        "symfony/monolog-bundle": "^3.10",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "dg/bypass-finals": "^1.9"
    },
    "autoload": {
        "psr-4": {
            "MyFlyingBox\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MyFlyingBox\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "installer-name": "MyFlyingBox"
    },
    "config": {
        "allow-plugins": {
            "thelia/installer": true
        }
    }
}
